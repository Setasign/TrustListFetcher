{
    "name": "setasign/trust-list-fetcher",
    "description": "A PHP package that allows you to download or extract all certificates from trust lists such as the EUTL or AATL.",
    "type": "library",
    "require": {
        "php": "^8.4",
        "ext-dom": "*",
        "ext-openssl": "*",
        "setasign/setapdf-signer": "^2.51.0.2285",
        "guzzlehttp/guzzle": "^7.0",
        "phpseclib/phpseclib": "^3.0.51"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "setasign\\TrustListFetcher\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://www.setasign.com/downloads/"
        }
    ]
}
